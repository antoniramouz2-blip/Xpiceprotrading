{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "balance": { "type": "number", "description": "Current USDT balance" },
        "hasUsedXpice": { "type": "boolean", "description": "Whether the user has used the xpice code" },
        "status": { "type": "string", "enum": ["active", "suspended"], "description": "Account status" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "balance"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Deposit transaction record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "amount": { "type": "number" },
        "network": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "network", "status", "createdAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Withdrawal transaction record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "amount": { "type": "number" },
        "network": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "network", "address", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Deposit requests"
    },
    "withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Withdrawal requests"
    }
  }
}
