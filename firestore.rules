rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, admin|user)
    //   - balance: number (required)
    //   - hasUsedXpice: boolean
    //   - status: string (active|suspended)
    //   - createdAt: timestamp
    //
    // Collection: deposits
    // Fields:
    //   - uid: string (required)
    //   - amount: number (required)
    //   - network: string (required)
    //   - status: string (pending|completed|rejected)
    //   - createdAt: timestamp
    //
    // Collection: withdrawals
    // Fields:
    //   - uid: string (required)
    //   - amount: number (required)
    //   - network: string (required)
    //   - address: string (required)
    //   - status: string (pending|completed|rejected)
    //   - createdAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "antoniramouz2@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'balance']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.balance is number &&
             (!('hasUsedXpice' in data) || data.hasUsedXpice is bool);
    }

    function isValidDeposit(data) {
      return data.keys().hasAll(['uid', 'amount', 'network', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status == 'pending';
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['uid', 'amount', 'network', 'address', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount >= 10 &&
             data.status == 'pending';
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /deposits/{depositId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDeposit(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
